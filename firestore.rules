rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // For development/testing purposes - more permissive rules
    // WARNING: Remove this for production!
    // Uncomment the rules below for testing if authentication is not set up yet:
    /*
    match /{document=**} {
      allow read, write: if true;
    }
    */
    
    // Example of more specific rules for different collections:
    /*
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    */
  }
}